<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <title>Bienvenue au Port Russell</title>
    <link rel="stylesheet" href="/style.css" />
  </head>
  <body class="login-page">
    <div class="login-container">
      <header>
        <h2>⚓ Port Russell</h2>
        <p>
          Système de gestion informatisée du port de plaisance. Accédez à la
          gestion des catways et des réservations.
        </p>
      </header>
      <main>
        <form id="loginForm">
          <input type="email" id="email" placeholder="Email" required />
          <input
            type="password"
            id="password"
            placeholder="Mot de passe"
            required
          />
          <button type="submit" class="login-btn">Se connecter</button>
        </form>
        <p id="error-msg"></p>
      </main>
    </div>
    <script src="/script.js"></script>
  </body>
</html>
